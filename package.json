{
  "name": "c-o-visualization",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "engines": {
    "node": ">=20 <23"
  },
  "scripts": {
    "dev": "concurrently -k -n API,WEB \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "node --watch server/server.js",
    "dev:client": "vite",
    "build": "vite build",
    "start": "node server/server.js",
    "check": "node --check server/server.js && node --check server/app.js && node --check server/config.js",
    "test": "node --test server/tests/orderStore.test.js"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "read-excel-file": "^9.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "vite": "^6.4.0"
  }
}
